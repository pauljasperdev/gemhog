{
  "name": "gemhog",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "sso": "aws sso login --sso-session=gemhog",
    "bootstrap": "./scripts/bootstrap.sh",
    "build": "pnpm -r build",
    "check": "biome check --error-on-warnings --write . && pnpm -r check-types",
    "test": "./scripts/test.sh",
    "test:audit": "pnpm audit --audit-level moderate --ignore-unfixable",
    "db:start": "docker compose -f ./infra/docker-compose.yml up -d",
    "db:watch": "docker compose -f ./infra/docker-compose.yml up",
    "db:stop": "docker compose -f ./infra/docker-compose.yml stop",
    "db:down": "docker compose -f ./infra/docker-compose.yml down",
    "db:migrate": "pnpm --filter @gemhog/core db:migrate",
    "format:md": "prettier --write \"**/*.md\"",
    "prepare": "lefthook install",
    "dev": "pnpm -r dev",
    "dev:web": "pnpm --filter web dev",
    "dev:server": "pnpm --filter server dev",
    "dev:db:push": "LOCAL_ENV=1 pnpm --filter @gemhog/core db:push",
    "dev:db:studio": "LOCAL_ENV=1 pnpm --filter @gemhog/core db:studio",
    "dev:db:generate": "LOCAL_ENV=1 pnpm --filter @gemhog/core db:generate",
    "dev:db:migrate": "LOCAL_ENV=1 pnpm --filter @gemhog/core db:migrate",
    "sst:dev": "pnpm sst dev",
    "sst:db:push": "sst shell -- pnpm --filter @gemhog/core db:push",
    "sst:db:studio": "sst shell -- pnpm --filter @gemhog/core db:studio",
    "sst:db:generate": "sst shell -- pnpm --filter @gemhog/core db:generate",
    "sst:db:migrate": "sst shell -- pnpm --filter @gemhog/core db:migrate"
  },
  "dependencies": {
    "@gemhog/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@gemhog/config": "workspace:*",
    "@playwright/mcp": "0.0.47",
    "@playwright/test": "^1.57.0",
    "@types/node": "^22.13.14",
    "@vitest/coverage-v8": "^4.0.17",
    "happy-dom": "^20.3.3",
    "lefthook": "^2.0.15",
    "prettier": "^3.8.0",
    "sst": "3.17.37",
    "typescript": "catalog:",
    "vitest": "^4.0.17"
  },
  "packageManager": "pnpm@10.15.1",
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0",
      "lodash-es": ">=4.17.23"
    },
    "auditConfig": {}
  }
}
